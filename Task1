<!DOCTYPE html>
<html lang="az">
<head>
    <meta charset="UTF-8">
    <title>Tapşırıq 1</title>
</head>
<body>

    <input type="text" id="textInput" placeholder="Mətn yazın">
    <button onclick="showText()">Göstər</button>

    <p id="result"></p>

    <script>
        function showText() {
            let text = document.getElementById("textInput").value;
            document.getElementById("result").innerText = text;
        }
    </script>

</body>
</html>
